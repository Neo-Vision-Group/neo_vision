NEXT_PUBLIC_SANITY_PROJECT_ID="your_project_id"
NEXT_PUBLIC_SANITY_DATASET="production"
NEXT_PUBLIC_SANITY_API_VERSION="2025-09-25"
NEXT_PUBLIC_SANITY_STUDIO_URL="http://localhost:3333"
SANITY_API_READ_TOKEN="your_read_token"
SANITY_WRITE_TOKEN="your_write_token"

# Resend config

RESEND_API_KEY="your_resend_api_key"
RESEND_FROM="nvt.dev@neovision.dev"
CONTACT_TO="razvan.andronachi@neovision.dev"

# Analytics

NEXT_PUBLIC_PLAUSIBLE_SCRIPT_URL="https://plausible.io/js/pa-XXXXX.js" # Required - Your Plausible script URL from dashboard
NEXT_PUBLIC_POSTHOG_PROJECT_TOKEN="public_posthog_project_token"
NEXT_PUBLIC_POSTHOG_HOST="https://eu.i.posthog.com"
POSTHOG_SERVER_API_KEY="server_side_posthog_api_key" # Separate server-side token for security
ALLOWED_RESOURCE_HOSTS="assets.neovision.dev,downloads.neovision.dev" # Optional - extra hosts allowed for emailed resource links

# Rate Limiting (Upstash Redis - REQUIRED for production)
# Get credentials from https://console.upstash.com/
# Without these, the site will fall back to in-memory rate limiting (not production-safe)

UPSTASH_REDIS_REST_URL="https://your-redis-url.upstash.io"
UPSTASH_REDIS_REST_TOKEN="your_upstash_token"

# Site

NEXT_PUBLIC_SITE_URL="http://localhost:3000"

# Dev

NODE_ENV="development"
