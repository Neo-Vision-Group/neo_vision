{
  "name": "neoxai",
  "description": "Neo xAI - AI-native engineering and transformation for companies that need working systems, not slide decks. We embed in your business, prove ROI, then scale it.",
  "keywords": [
    "AI",
    "Software",
    "Development",
    "Engineering",
    "Transformation",
    "Future"
  ],
  "homepage": "https://neovision.dev",
  "workspaces": [
    "studio",
    "frontend"
  ],
  "scripts": {
    "dev": "npx run-p --print-label dev:*",
    "dev:next": "npm run dev --workspace=frontend",
    "dev:studio": "npm run dev --workspace=studio",
    "format": "prettier --cache --write .",
    "import-sample-data": "cd studio && sanity dataset import sample-data.tar.gz --dataset production --replace",
    "lint": "npm run lint --workspace=frontend",
    "type-check": "npm run type-check --workspaces"
  },
  "prettier": "@sanity/prettier-config",
  "devDependencies": {
    "@sanity/prettier-config": "^3.0.0",
    "npm-run-all2": "^5.0.2",
    "prettier": "^3.8.1"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@next/third-parties": "^16.2.9",
    "swiper": "^12.2.0"
  }
}
