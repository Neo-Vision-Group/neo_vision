{
  "name": "studio",
  "version": "1.0.0",
  "private": true,
  "keywords": [
    "sanity"
  ],
  "license": "UNLICENSED",
  "main": "package.json",
  "scripts": {
    "build": "sanity build",
    "deploy": "sanity deploy",
    "predev": "npm run sanity:typegen",
    "dev": "sanity dev",
    "sanity:typegen": "sanity schema extract --enforce-required-fields --path ../sanity.schema.json && sanity typegen generate",
    "start": "serve dist -l tcp://0.0.0.0:${PORT:-3333} --single",
    "type-check": "tsc --noEmit",
    "migrate:set-project-references": "npx tsx migrations/set-project-industry-and-service/index.ts"
  },
  "dependencies": {
    "@sanity/assist": "^6.0.4",
    "serve": "^14.2.4",
    "@sanity/icons": "^3.7.4",
    "@sanity/vision": "^5.24.0",
    "date-fns": "^4.1.0",
    "pluralize-esm": "^9.0.5",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "rxjs": "^7.8.2",
    "sanity": "^5.24.0",
    "sanity-plugin-asset-source-unsplash": "^7.0.5",
    "sanity-plugin-media": "^4.1.1",
    "styled-components": "^6.3.12"
  },
  "devDependencies": {
    "@sanity/eslint-config-studio": "^6.0.0",
    "@types/react": "^19.2.14",
    "typescript": "^5.9.3"
  }
}
